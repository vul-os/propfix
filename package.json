{
  "name": "propfix",
  "version": "0.1.0",
  "private": true,
  "description": "Building maintenance and inspections you actually own. One static binary, one SQLite file.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/vul-os/propfix.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:all": "vite build && cp -r site backend/cmd/propfix/site && cp -r dist backend/cmd/propfix/dist && cd backend && go build -tags embed_frontend -ldflags \"-X main.version=$npm_package_version\" -o propfix ./cmd/propfix && cd .. && rm -rf backend/cmd/propfix/site backend/cmd/propfix/dist",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "screenshots": "node scripts/screenshots.mjs",
    "qa-shots": "node scripts/qa-shots.mjs",
    "docs:sync": "node scripts/sync-docs.mjs",
    "docs:check": "node scripts/sync-docs.mjs --check"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.56.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "vite": "^5.4.20",
    "vitest": "^2.1.9"
  }
}
