<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="stylesheet" href="styles.css">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PropFix</title>
  <style>
    body, a, .hero-buttons a {
      color: #7A0008 !important;
    }

    html, body {
      height: 100%;
      margin: 0;
    }

    h2 {
      opacity: 0; /* Start with zero opacity */
      margin-top: 16px;
      color: black;
      text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
      transition: opacity 3s ease;
    }

    body {
      background: linear-gradient(to bottom, #F9FAFB);
      display: flex;
      flex-direction: column;
    }

    .custom-bg {
      background: none;
      background-color: #EBF2FA;
    }

    .fade-in {
      opacity: 1;
      animation: fadeIn 3s ease forwards; /* Updated animation duration to 3 seconds */
    }

    @keyframes fadeIn {
      0% {
        opacity: 0;
      }
      100% {
        opacity: 1;
      }
    }

    .highlight {
      color: #7A0008;
    }

    .content-container {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 0; /* Adjust the padding to create space between elements */
    }

    .illustration-animation {
      animation: moveRight 3s ease-in-out infinite alternate; /* Animation for the illustration */
    }

    @keyframes moveRight {
      0% {
        transform: translateX(0);
      }
      100% {
        transform: translateX(20px); /* Move the illustration 20px to the right */
      }
    }

    p {
      text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.3);
    }
  </style>
</head>
<body>
  <section class="custom-bg">
    <div class="mx-auto w-full lg:px-24 max-w-7xl md:px-12 items-center px-8 py-32">
      <div class="text-center max-w-4xl mx-auto">
        <div class="sm:flex sm:justify-center">
          <div class="relative rounded-full py-1 px-3 text-sm leading-6 text-gray-600 ring-1 ring-gray-900/10 hover:ring-gray-900/20">
            <a href="https://propfix.com" class="font-semibold text-indigo-600">
              <span class="absolute inset-0" aria-hidden="true"></span>
            </a>
          </div>
        </div>
        <div class="content-container">
          <div class="w-full md:w-7/12 mb-4 md:mb-0">
            <h2 class="text-black font-extrabold lg:text-5xl text-4xl tracking-tighter fade-in">
              <span style="margin-right: 1rem;">Log -</span>
              <span style="margin-right: 1rem; color: #7A0008;">Look -</span>
              <span style="margin-right: 1rem;">List -</span>
              <span style="color: #7A0008;">Mend</span>
            </h2>
            <p class="mt-4 text-lg max-w-xl mx-auto tracking-tight fade-in" style="color: #000000;">
              Streamline your property management with Prop  Fix. Say goodbye to disorganized workflows, missing information, and repetitive tasks. Say hello to efficiency and seamless management with PropFix.
            </p>
          </div>
          <div class="w-full md:w-5/12 isometric-illustration illustration-animation" style="position: relative; left: 50px;">
            <img src="public/propfixisometricpic.png" alt="Isometric Illustration" class="w-full rounded-lg shadow-2xl" />
          </div>
        </div>
        <div class="flex justify-center gap-3 mt-10 flex-col sm:flex-row hero-buttons fade-in">
          <a class="items-center justify-center h-12 font-medium rounded-xl focus-visible:outline-black focus:outline-none inline-flex duration-200 text-white lg:w-auto px-6 py-3 text-center" href="https://propfix.com" style="background-color: #F9FAFB; color: #7A0008;">
            Visit PropFix &nbsp; &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>
</body>
</html>
